# ==============================================
# AGENTE WHATSAPP + CLAUDE — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env com valores reais para o Git!

# ----------------------------------------------
# OBRIGATÓRIO — Chave da API Anthropic
# Obtenha em: https://console.anthropic.com/
# ----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-COLOQUE_SUA_CHAVE_AQUI

# ----------------------------------------------
# OPCIONAL — Configurações do agente
# ----------------------------------------------

# Nível de log: silent | error | warn | info | debug
LOG_LEVEL=info

# Porta HTTP (para uso futuro / healthcheck externo)
PORT=3000
