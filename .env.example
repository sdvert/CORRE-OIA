# ══════════════════════════════════════════════════════════════
#  WhatsApp Claude Agent — Variáveis de Ambiente
#  Copie para .env e preencha. NUNCA suba o .env para o Git!
# ══════════════════════════════════════════════════════════════

# ── OBRIGATÓRIO ──────────────────────────────────────────────
# Chave da API Anthropic → https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-COLOQUE_SUA_CHAVE_AQUI

# Chave da API ClickUp → https://app.clickup.com/settings/apps
CLICKUP_API_KEY=pk_COLOQUE_SUA_CHAVE_AQUI

# Team ID do ClickUp → número na URL: app.clickup.com/90171209803/...
CLICKUP_TEAM_ID=COLOQUE_SEU_TEAM_ID_AQUI

# ── OPCIONAL ─────────────────────────────────────────────────
# Pasta de sessão do WhatsApp (volume persistente no EasyPanel)
AUTH_FOLDER=/app/auth_info

# Caminho do banco SQLite (volume persistente no EasyPanel)
DB_PATH=/app/data/sessions.db
